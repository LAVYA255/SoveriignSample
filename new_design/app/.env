# ── Backend ─────────────────────────────────────────────────────
APP_ID=dummy-app-id                   # Application ID
APP_SECRET=dummy-app-secret               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=mysql://user:pass@localhost:3306/db             # MySQL connection string (mysql://user:pass@host:port/db)

# ── Frontend (exposed to browser via Vite) ──────────────────────
VITE_KIMI_AUTH_URL=https://dummy.auth.kimi.com       # Kimi OAuth server URL (e.g. https://auth.kimi.com)
VITE_APP_ID=dummy-app-id              # OAuth application ID

# ── Backend (Auth) ─────────────────────────────────────────────
KIMI_AUTH_URL=https://dummy.auth.kimi.com
KIMI_OPEN_URL=https://dummy.open.kimi.com

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=mock-admin-id           # Union ID of the app creator; this user gets role "admin" on first login
